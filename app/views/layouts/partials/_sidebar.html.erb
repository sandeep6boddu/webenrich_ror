<!-- START Sidebar (left)-->
<div class="aside-inner">
	<% if user_signed_in? %>
		<% if current_user.has_role?(:admin) %>
			<nav class="sidebar">
				<!-- START sidebar nav-->
				<ul class="nav">
					<li class="nav-heading">
						<span>Main Navigation</span>
					</li>
					<li class="<%= 'active' if controller?('admin') && action?('dashboard') %>">
