							<em class="icon-speedometer"></em>
							<span>Portfolio</span>
						</a>
						<ul id="portfolio" class="nav sidebar-subnav collapse">
							<li class="<%= 'active' if controller?('admin/portfolio') && action?('index') %>">
								<%= link_to portfolios_path, title: "list" do %>
								<span>List</span>
								<% end %>
							</li>
							<li class="<%= 'active' if controller?('admin/portfolio') && action?('new') %>">
