<!DOCTYPE html>
<html>
	<%= render 'layouts/parts/lp/head' %>
	<body>
        <script type="text/javascript">
			jQuery(document).ready(function(){
				var status = "<%= alert.present? %>";
				if( status == "true"){
					swal("<%= alert %>", "We will get back you soon!", "success");
				}
			});
        </script>
		<%= render 'layouts/parts/lp/header' %>
		<%= yield %>
		<%= render 'layouts/parts/lp/footer' %>
	</body>
</html>