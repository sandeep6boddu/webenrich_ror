<% content_for :title do %>
	Blogs
<% end %>
<div class="container">
	<h1 class="margin-top">
		<%= link_to '/' do %>Blog<% end %>
	</h1>
</div>
<div class="container">
	<div class="row">
		<div class="col s12">
			<% if @blogs.count > 0 %>
				<% @blogs.each do |blog| %>
					<% if blog.banner.present? %>
						<div class="card card-6 margin-right left">
							<div class="card-image">
								<%= link_to blog_show_path(blog.slug) do %>
									<%= image_tag blog.banner.url(:medium), :alt => 'Banner Image', :class => 'img-responsive' %>
								<% end %>
								<div class="left">
									<span class="card-title cust-card-title">
										<%= link_to blog_show_path(blog.slug) do %>
											<%= raw truncate(blog.title, length: 26, escape: false) %>
										<% end %>
									</span>
								</div>
							</div>
							<div class="card-content">
								<div class="left">
									<span class="mdl-color-text--red">
										<%= blog.categories.pluck(:name).join(', ') %>
									</span>
								</div>
								<div class="right">
									<%= link_to blog_show_path(blog.slug) + "#comments" , class: 'right' do %>
										<i class="material-icons">comment</i>
									<% end %>
								</div>
								<div class="clear"></div>
								<p>
									<%= raw truncate(blog.content, length: 240, escape: false) %>
								</p>
							</div>
						</div>
					<% else %>
					<div class="card card-6 margin-right left">
						<div class="card-image blue-patch">
							<%= link_to blog_show_path(blog.slug), :class => 'left' do %>
								<%= button_tag 'Readmore', :class => 'mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect left mdl-color-text--white' %>
							<% end %>
							<%= link_to blog_show_path(blog.slug) + "#comments" , class: 'right' do %>
								<i class="material-icons">comment</i>
							<% end %>
						</div>
						<div class="clear"></div>
						<div class="card-content">
							<span class="mdl-color-text--red">
								<%= blog.categories.pluck(:name).join(', ') %>
							</span>
							<div class="clear"></div>
							<h3 class="">
								<%= link_to blog_show_path(blog.slug) do %>
									<%= raw truncate(blog.title, length: 30, escape: false) %>
								<% end %>
							</h3>
							<div class="clear"></div>
							<span class="post-time margin-top left">
								<i class="material-icons left">schedule</i>
								<% subs = {"about" => '', "almost" => '', "over" => ''} %>
								<%= distance_of_time_in_words_to_now(blog.created_at).gsub(/\w+/) { |word| subs[word] || word} %> ago
							</span>
							<div class="clear margin-top"></div>
							<p class="left margin-top">
								<%= raw truncate(blog.content, length: 40, escape: false) %>
							</p>
							<div class="clear"></div>
							<div class="blogcomments-icons">
								<ul class="post-comments">
									<li>
										<i class="material-icons mdl-color-text--light-blue-500 left">comment</i>30
									</li>
								</ul>
							</div>
						</div>
					</div>
				<% end %>
			<% end %>
			<% else %>
				<span>No more blogs under this category.</span>
			<% end %>
		</div>
	</div>
</div>