<% content_for :title do %>
	Request A Quote from WebEnrich!
<% end %>
<% content_for :meta_tags do %>
	<meta name="description" content="Web Enrich Services: Select from the list of Internet Marketing & Web Based services that we offer and Hire us to handle you project successfully">
	<meta name="keywords" content="WebEnrich services, India, internet marketing, online marketing, web based services, hire us, consultant">
<% end %>
<div class="jobs-inner-page request-a-quote">
	<div class="mobile-page-main">
		<div class="main-title">
			<div class="container">
				<h1>
					<span class="left quote-icon">
						<%= image_tag image_path('mobile/request-a-quote.png') %>
					</span>
					Request a Quote
					<%= link_to root_path, :class => 'right' do %>
						<%= image_tag image_path('mobile/close-icon.png') %>
					<% end %>
				</h1>
			</div>
		</div>
	</div>
	<div class="clear"></div>
	<div class="job-description job-detaile-page">
		<div class="container">
			<div class="col s12">
				<div class="card job-card">
					<div class="container">
						<h2 class="form-titles-main">Personal Info</h2>
						<%= form_for @quote do |f| %>
							<div id="test1" class="col s12">
								<div class="form-content">
									<div class="row">
										<div class="input-field col s12">
											<div class="alert-danger right contact-errors"><%= @quote.errors[:full_name].join(', ') %></div>
											<%= f.text_field :full_name, :class => 'mdl-textfield__input' %>
											<%= label_tag 'name' do %>
												Full Name: <sup class="star">*</sup>
											<% end %>
										</div>
									</div>
									<div class="row">
										<div class="input-field col s12">
											<div class="alert-danger right contact-errors"><%= @quote.errors[:email_address].join(', ') %></div>
											<%= f.email_field :email_address, :class => 'mdl-textfield__input' %>
											<%= label_tag 'name' do %>
												Email Address: <sup class="star">*</sup>
											<% end %>
										</div>
									</div>
									<div class="row">
										<div class="input-field col s12">
											<div class="alert-danger right phone contact-errors"><%= @quote.errors[:phone].join(', ') %></div>
											<%= f.text_field :phone, :class => 'mdl-textfield__input', :pattern => '-?[0-9]*(\.[0-9]+)?' %>
											<%= label_tag 'name' do %>
												Phone: <sup class="star">*</sup>
											<% end %>
										</div>
									</div>
									<div class="row">
										<div class="input-field col s12">
											<div class="alert-danger right contact-errors"><%= @quote.errors[:company_name].join(', ') %></div>
											<%= f.text_field :company_name, :class => 'mdl-textfield__input' %>
											<%= label_tag 'name' do %>
												Business Name: <sup class="star">*</sup>
											<% end %>
										</div>
									</div>
									<div class="row">
										<div class="input-field col s12">
											<div class="alert-danger right contact-errors"><%= @quote.errors[:website_url].join(', ') %></div>
											<%= f.text_field :website_url, :class => 'mdl-textfield__input' %>
											<%= label_tag 'name' do %>
												Website URL
											<% end %>
											<em class="example-text">(eg;- http://www.yourwebsite.com)</em>
										</div>
									</div>
									<div class="col s12 interested-in">
										<h2 class="form-titles-main">Project Details</h2>
										<label class="request-questions">
											<strong class="form-title-inner">
												What are you interested in?
											</strong>
											<span>
												<% @arry =  @quote.interested_in.reject {|a| a.empty?} %>
												<%= "Please select atleast one option." if @arry.length <= 0 %>
											</span>
										</label>
										<div class="col-md-6 col-sm-6 no-padding-left">
											<div class="quote-item" data-value="business">
												<div class="project-type business <%= (@quote.interested_in.nil? ? '' : (@quote.interested_in.include?('business') ? 'active-tab' : '' )) %>">
													<%= hidden_field_tag 'quote[interested_in][]', (@quote.interested_in.nil? ? '' : (@quote.interested_in.include?('business') ? 'business' : '' )) %>
													<div class="website-type">
														<h3>Business/Professional Website
														</h3>
													</div>
												</div>
											</div>
										</div>
										<div class="col-md-6 col-sm-6 no-padding-right">
											<div class="quote-item"  data-value="ecommerce">
												<div class="project-type ecommerce-web <%= (@quote.interested_in.nil? ? '' : (@quote.interested_in.include?('ecommerce') ? 'active-tab' : '' )) %>">
													<%= hidden_field_tag 'quote[interested_in][]', (@quote.interested_in.nil? ? '' : (@quote.interested_in.include?('ecommerce') ? 'ecommerce' : '' )) %>
													<div class="website-type">
														<h3>E-commerce Website</h3>
													</div>
												</div>
											</div>
										</div>
										<div class="col-md-6 col-sm-6 no-padding-left">
											<div class="quote-item" data-value="cms">
												<div class="project-type cms <%= (@quote.interested_in.nil? ? '' : (@quote.interested_in.include?('cms') ? 'active-tab' : '' )) %>">
													<%= hidden_field_tag 'quote[interested_in][]', (@quote.interested_in.nil? ? '' : (@quote.interested_in.include?('cms') ? 'cms' : '' )) %>
													<div class="website-type">
														<h3>Content Management System</h3>
													</div>
												</div>
											</div>
										</div>
										<div class="col-md-6 col-sm-6 no-padding-right">
											<div class="quote-item" data-value="social">
												<div class="project-type social  <%= (@quote.interested_in.nil? ? '' : (@quote.interested_in.include?('social') ? 'active-tab' : '' )) %>">
													<%= hidden_field_tag 'quote[interested_in][]', (@quote.interested_in.nil? ? '' : (@quote.interested_in.include?('social') ? 'social' : '' )) %>
													<div class="website-type">
														<h3>Social Website</h3>
													</div>
												</div>
											</div>
										</div>
										<div class="col-md-6 col-sm-6 no-padding-left">
											<div class="quote-item" data-value="portal">
												<div class="project-type portal  <%= (@quote.interested_in.nil? ? '' : (@quote.interested_in.include?('portal') ? 'active-tab' : '' )) %>">
													<%= hidden_field_tag 'quote[interested_in][]', (@quote.interested_in.nil? ? '' : (@quote.interested_in.include?('portal') ? 'portal' : '' )) %>
													<div class="website-type">
														<h3>Portal</h3>
													</div>
												</div>
											</div>
										</div>
										<div class="col-md-6 col-sm-6 no-padding-right">
											<div class="quote-item" data-value="other-web">
												<div class="project-type other-web  <%= (params['quote']['interested_in'][5].nil?  ? '' : (params['quote']['interested_in'][5].present? ? 'active-tab' : '' )) if @quote.interested_in.present? %>">
													<div class="website-type other-website">
														<h3>Other Website</h3>
														<input type="text"  name="quote[interested_in][]" class="other-text" value="<%= params['quote']['interested_in'][5] if @quote.interested_in.present? %>" />
													</div>
												</div>
											</div>
										</div>
									</div>
									<div class="col s12 also-interested-in">
										<label class="request-questions">
											<strong class="form-title-inner">Also interested in?</strong>
											<span>
												<% @arry =  @quote.also_interested_in.reject {|a| a.empty?} %>
												<%= "Please select atleast one option." if @arry.length <= 0 %>
											</span>
										</label>
										<div class="col-md-6 col-sm-6 no-padding-left">
											<div class="quote-item" data-value="seo">
												<div class="project-type seo-request <%= (@quote.also_interested_in.nil? ? '' : (@quote.also_interested_in.include?('seo') ? 'active-tab' : '' )) %>">
													<%= hidden_field_tag 'quote[also_interested_in][]', (@quote.also_interested_in.nil? ? '' : (@quote.also_interested_in.include?('seo') ? 'seo' : '' )) %>
													<div class="website-type">
														<h3>Search Engine Optimization</h3>
													</div>
												</div>
											</div>
										</div>
										<div class="col-md-6 col-sm-6 no-padding-right">
											<div class="quote-item" data-value="smm">
												<div class="project-type smm-request <%= (@quote.also_interested_in.nil? ? '' : (@quote.also_interested_in.include?('smm') ? 'active-tab' : '' )) %>">
													<%= hidden_field_tag 'quote[also_interested_in][]', (@quote.also_interested_in.nil? ? '' : (@quote.also_interested_in.include?('smm') ? 'smm' : '' )) %>
													<div class="website-type">
														<h3>Social Media Marketing</h3>
													</div>
												</div>
											</div>
										</div>
										<div class="col-md-6 col-sm-6 no-padding-left">
											<div class="quote-item" data-value="ppc">
												<div class="project-type ppc-request  <%= (@quote.also_interested_in.nil? ? '' : (@quote.also_interested_in.include?('ppc') ? 'active-tab' : '' )) %>">
													<%= hidden_field_tag 'quote[also_interested_in][]', (@quote.also_interested_in.nil? ? '' : (@quote.also_interested_in.include?('ppc') ? 'ppc' : '' )) %>
													<div class="website-type">
														<h3>Pay Per Click</h3>
													</div>
												</div>
											</div>
										</div>
										<div class="col-md-6 col-sm-6 no-padding-right">
											<div class="quote-item" data-value="other-request">
												<div class="project-type other-request  <%= (params['quote']['also_interested_in'][3].nil?  ? '' : (params['quote']['also_interested_in'][3].present? ? 'active-tab' : '' )) if @quote.also_interested_in.present? %>">
													<%#= hidden_field_tag 'quote[also_interested_in][]', (@quote.also_interested_in.nil? ? '' : (@quote.also_interested_in.include?('other-request') ? 'other-request' : '' )) %>
													<div class="website-type other-website">
														<h3>Other</h3>
														<input type="text"  name="quote[also_interested_in][]" class="other-text" value="<%= params['quote']['also_interested_in'][3] if @quote.also_interested_in.present? %>" />
													</div>
												</div>
											</div>
										</div>
									</div>
									<div class="clear"></div>
									<!-- website-budget -->
									<div class="websit-budget-section">
										<div class="col s12">
											<h1 class="form-title">Approximate website budget?</h1>
											<%= "Please select atleast one option." if @quote.budget.nil? %>
											<div class="request-block quote-budget-input">
												<div class="quote-item quote-budget" data-value="dollars_0_25k">
													<div class="project-type request-budget  <%= "active-tab" if @quote.budget.present? && params["quote"]["budget"] == 'dollars_0_25k' %>">
														<div class="website-type">
															<h3><span>Under</span> $25,000</h3>
														</div>
													</div>
												</div>
												<div class="quote-item quote-budget" data-value="dollars_25k_50k">
													<div class="project-type request-budget <%= "active-tab" if @quote.budget.present? && params["quote"]["budget"] == 'dollars_25k_50k' %>">
														<div class="website-type">
															<h3>$25,000 - $50,000</h3>
														</div>
													</div>
												</div>
												<div class="quote-item quote-budget" data-value="dollars_50k_1lakh">
													<div class="project-type request-budget <%= "active-tab" if @quote.budget.present? && params["quote"]["budget"] == 'dollars_50k_1lakh' %>">
														<div class="website-type">
															<h3>$50,000 - $1,00,000</h3>
														</div>
													</div>
												</div>
												<div class="quote-item quote-budget" data-value="not_sure">
													<div class="project-type request-budget <%= "active-tab" if @quote.budget.present? && params["quote"]["budget"] == 'not_sure' %>">
														<div class="website-type">
															<h3><span>Not Sure</span></h3>
														</div>
													</div>
												</div>
												<%= hidden_field_tag 'quote[budget]', @quote.budget %>
											</div>
										</div>
									</div>
									<!-- ideal project start date -->
									<div class="request-block start-date-input">
										<div class="col s12">
											<h1 class="form-title">Select an ideal start date:</h1>
											<%= "Please select atleast one option." if @quote.start_date.nil? %>
											<div class="quote-item start-date" data-value="immediately">
												<div class="project-type request-budget <%= "active-tab" if @quote.start_date.present? && params["quote"]["start_date"] == 'immediately' %>">
													<div class="website-type">
														<h3><span>Immediately</span></h3>
													</div>
												</div>
											</div>
											<div class="quote-item start-date" data-value="this_month">
												<div class="project-type request-budget <%= "active-tab" if @quote.start_date.present? && params["quote"]["start_date"] == 'this_month' %>">
													<div class="website-type">
														<h3><span>This Month</span></h3>
													</div>
												</div>
											</div>
											<div class="quote-item start-date" data-value="near_future">
												<div class="project-type request-budget <%= "active-tab" if @quote.start_date.present? && params["quote"]["start_date"] == 'near_future' %>">
													<div class="website-type">
														<h3><span>Near Future</span></h3>
													</div>
												</div>
											</div>
											<div class="quote-item start-date" data-value="this_year">
												<div class="project-type request-budget <%= "active-tab" if @quote.start_date.present? && params["quote"]["start_date"] == 'this_year' %>">
													<div class="website-type">
														<h3><span>This Year</span></h3>
													</div>
												</div>
											</div>
											<%= hidden_field_tag 'quote[start_date]', @quote.start_date %>
										</div>
									</div>
									<div class="clear"></div>
									<!--describe your project-->
									<div class="other-project-details">
										<div class="request-block project-details">
											<div class="input-field">
												<div class="alert-danger right contact-errors"><%= @quote.errors[:project_details].join(', ') %></div>
												<%= f.text_area :project_details, :class => 'materialize-textarea' %>
												<%= label_tag 'name' do %>
													Describe your project:
												<% end %>
											</div>
										</div>
										<div class="request-block competitors">
											<div class="input-field">
												<div class="alert-danger right contact-errors"><%= @quote.errors[:competitors].join(', ') %></div>
												<%= f.text_area :competitors, :class => 'materialize-textarea' %>
												<%= label_tag 'name' do %>
													List your competitors:
												<% end %>
											</div>
										</div>
										<div class="request-block target-audience">
											<div class="input-field">
												<div class="alert-danger right contact-errors"><%= @quote.errors[:target_audience].join(', ') %></div>
												<%= f.text_area :target_audience, :class => 'materialize-textarea' %>
												<%= label_tag 'name' do %>
													Target audience?:
												<% end %>
											</div>
										</div>
										<div class="request-block anything-else">
											<div class="input-field">
												<div class="alert-danger right contact-errors"><%= @quote.errors[:anything_else].join(', ') %></div>
												<%= f.text_area :anything_else, :class => 'materialize-textarea' %>
												<%= label_tag 'name' do %>
													Message:
												<% end %>
											</div>
										</div>
									</div>
								</div>
								<div class="clear">
									<div class="captch">
										<%= recaptcha_tags %>
									</div>
									<div class="request-quote-captcha">
										<%= @quote.errors["g-recaptcha-response"].join(', ') %>
									</div>
								</div>
								<%= f.submit 'REQUEST A QUOTE NOW!', :class => 'submit btn margin-top' %>
							</div>
						<% end %>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>