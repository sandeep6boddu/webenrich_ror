<div class="table-responsive"> 
	<table class="table">
		<thead>
			<tr>
				<th class="text-center text-capitalize">&nbsp;</th>
				<th class="text-center text-capitalize">&nbsp;</th>
				<th class="text-left text-capitalize">List of Users</th>
				<th class="text-center text-capitalize">&nbsp;</th>
			</tr>
			<tr>
				<th class="text-center">First Name</th>
				<th class="text-center">Last Name</th>
				<th class="text-center">Email</th>
				<th>&nbsp;</th>
			</tr>
		</thead>
		<% @users.each do |user| %>
			<% if current_user != user %>
				<tbody>
					<tr>
						<td class="text-center"><%= user.firstname %></td>
						<td class="text-center"><%= user.lastname %></td>
						<td class="text-center"><%= user.email %></td>
						<td class="text-center"><%= link_to 'Show', user_path(user) %>&nbsp; &nbsp;| &nbsp;&nbsp;<%= link_to 'Edit', edit_user_path(user) %>&nbsp; &nbsp;| &nbsp;&nbsp;<%= link_to 'Delete', user_path(user), :method => 'delete', :data => {:confirm => "Are you sure you want to delete user?"} %></td>
					</tr>
				</tbody>
			<% end %>
		<% end %>
	</table>
</div>