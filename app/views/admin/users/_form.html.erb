<div class="panel-heading text-center">
	<a href="#">
		<img src="<%= image_path('logos/icon.png') %>" alt="Image" class="block-center img-rounded" />
	</a>
</div>
<div class="panel-body">
	<p class="text-center pv">Add User</p>
	<%= form_for @user do |f| %>
		<%#= devise_error_messages! %>
		<div class="form-group has-feedback">
				<%= f.label :Firstname %><br />
				<%= f.text_field :firstname, autofocus: true, placeholder: "Firstname",autocomplete: "off", required: "required", class: "form-control" %>
			 <span class="fa fa-envelope form-control-feedback text-muted"></span>
		</div>
		<div class="form-group has-feedback">
				<%= f.label :Lastname %><br />
				<%= f.text_field :lastname, autofocus: true, placeholder: "Enter email",autocomplete: "off", required: "required", class: "form-control" %>
			 <span class="fa fa-envelope form-control-feedback text-muted"></span>
		</div>
		<div class="form-group has-feedback">
				<%= f.label :Email %><br />
				<%= f.email_field :email, autofocus: true, placeholder: "Enter email",autocomplete: "off", required: "required", class: "form-control" %>
			<span class="fa fa-envelope form-control-feedback text-muted"></span>
		</div>
	<% end %>
</div>