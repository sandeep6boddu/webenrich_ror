	</div>
	<div class="row">
		<div class="col-lg-9">
			<div class="clearfix">
				<div class="pull-right">
					<%= f.button "Save", :class => "btn btn-primary m-t-10" do %>
						<em class="fa fa-check fa-fw"></em> save
					<% end %>
				</div>
				<div class="pull-left">
					<%= link_to teams_path, :class => "btn btn-danger" do %>
						<i class="fa fa-undo"></i> Cancel
					<% end %>
				</div>
			</div>
