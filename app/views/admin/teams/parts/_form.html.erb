						<%#= f.text_field :meta_title, class: "form-control", placeholder: "Meta Title...", required: true %>
						<%#= @portfolio.errors[:meta_title].join(', ') %>
					</div>
					<div class="form-group col-md-12">
						<p>Description:</p>
						<%#= f.text_area :meta_description, class: "form-control", placeholder: "Max 255 characters...", rows: 5, required: true %>
