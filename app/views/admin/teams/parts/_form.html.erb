<div class="content-heading">WebEnrich Team</div>
<%= form_for @team, :data => {:parsley_validate=>""}, :html => {class: "form-horizontal", :multipart => true} do |f| %>
	<div class="row">
		<!-- Job Content-->
		<!-- START panel-->
		<div class="col-lg-9">
			<div class="panel panel-default">
				<div class="panel-body">
					<fieldset>
						<legend>New Team Member</legend>
					</fieldset>
					<fieldset>
						<div class="form-group">
							<label class="col-md-2 control-label">Upload Image:</label>
							<div class="col-md-8">
								<%= f.file_field :team_img, class: 'form-control filestyle', classinput: 'form-control inline', data: {:classbutton => "btn btn-default"} %>
								<%= @team.errors[:team_img].join(', ') %>
								<span>*Upload only JPG or PNG images.</span>
							</div>
						</div>
					</fieldset>
					<fieldset>
						<div class="form-group">
							<label class="col-md-2 control-label">Name:</label>
							<div class="col-md-8">
								<%= f.text_field :name, class: "form-control", placeholder: "Employee Name...", required: true %>
								<%= @team.errors[:name].join(', ') %>
							</div>
						</div>
					</fieldset>
					<fieldset>
						<div class="form-group">
							<label class="col-md-2 control-label">Designation:</label>
							<div class="col-md-8">
								<%= f.text_area :designation, class: "form-control", placeholder: "Designation..." %>
								<%= @team.errors[:designation].join(', ') %>
							</div>
						</div>
					</fieldset>
				</div>
			</div>
		</div>
		<!-- END panel-->
		<!-- Job sidebar-->
