<div class="content-heading">Categories</div>
<%= form_for @category, html: {class: "form-horizontal"}, :data => {:parsley_validate=>""} do |f| %>
	<div class="row">
		<!-- Category Content-->
		<!-- START panel-->
		<div class="col-lg-12 col-md-12">
			<div class="panel panel-default">
				<div class="panel-body">
					<fieldset>
						<legend>New Category</legend>
					</fieldset>
					<fieldset>
						<div class="form-group">
							<label class="col-md-2 control-label">Category Name:</label>
							<div class="col-md-8">
								<%= f.text_field :name, class: "form-control", placeholder: "Category Name...", required: true %>
								<%= @category.errors[:name].join(', ') %>
							</div>
						</div>
					</fieldset>
				</div>
			</div>
		</div>
		<!-- END panel-->
	</div>
	<div class="row">
		<div class="col-lg-12 col-md-12">
			<div class="clearfix">
				<div class="pull-right">
					<%= f.button "Save", :class => "btn btn-primary m-t-10" do %>
						<em class="fa fa-check fa-fw"></em> Save
					<% end %>
				</div>
				<div class="pull-left">
					<%= link_to categories_path, :class => "btn btn-danger" do %>
						<i class="fa fa-undo"></i> Cancel
					<% end %>
				</div>
			</div>
		</div>
	</div>
<% end %>
