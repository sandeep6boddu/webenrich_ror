<!-- Main section-->
<section>
	<!-- Page content-->
	<div class="content-wrapper">
		<div class="row">
			<!-- Blog Content-->
			<div class="col-lg-9">
				<div class="row">
					<!-- Posts column 1-->
					<% @blogs.each do |blog| %>
						<% if blog.banner.present? %>
							<div class="col-md-4 pull-left">
								<div class="panel">
									<%= link_to blog_show_path(blog.id) do %>
										<%= image_tag blog.banner.url(:medium), :alt => 'Banner Image', :class => 'img-responsive' %>
									<% end %>								
									<div class="panel-body">	
										<h4>
											<a href=""><%= blog.title %></a>
										</h4>
										<p>
											<%= raw truncate(blog.content, length: 120, escape: false) %>
										</p>
										<p class="clearfix">
											<span class="pull-left">
												<small class="mr-sm">Posted By 
													<a href="">
														<%= blog.user.email %>
													</a>
												</small>
												<small class="mr-sm">
													<% subs = {"about" => '', "almost" => '', "over" => ''} %>
													<%= distance_of_time_in_words_to_now(blog.created_at).gsub(/\w+/) { |word| subs[word] || word} %> ago
												</small>
											</span>
										</p>
										<%= link_to 'Show', blog_path(blog) %> &nbsp;&nbsp; 
										<% if current_user.has_role?(:admin) ||  blog.user == current_user %>
										| &nbsp;&nbsp;
											<%= link_to 'Edit', edit_blog_path(blog) %> &nbsp;&nbsp;| &nbsp;&nbsp;
											<%= link_to 'Delete',blog_path(blog), method: :Delete, data: {:confirm =>'Are you sure?'} %><br/>
										<% end %>
									</div>
								</div>
							</div>
						<% else %>
						<div class="col-md-4 pull-left">
								<div class="panel">			
									<div class="panel-body">
										<h4>
											<a href="">
												<%= blog.title %>
											</a>
										</h4>
										<p>
											<%= raw truncate(blog.content, length: 240, escape: false) %>
										</p><br/>
										<p class="clearfix">
											<span class="pull-left">
												<small class="mr-sm">Posted By 
													<a href="">
														<%= blog.user.email %>
													</a>
												</small>
												<small class="mr-sm">
													<% subs = {"about" => '', "almost" => '', "over" => ''} %>
													<%= distance_of_time_in_words_to_now(blog.created_at).gsub(/\w+/) { |word| subs[word] || word} %> ago
												</small>
											</span>
										</p>
										<%= link_to 'Show', blog_path(blog) %> &nbsp;&nbsp; 
										<% if current_user.has_role?(:admin) ||  blog.user == current_user %>
										| &nbsp;&nbsp;
											<%= link_to 'Edit', edit_blog_path(blog) %> &nbsp;&nbsp;| &nbsp;&nbsp;
											<%= link_to 'Delete',blog_path(blog), method: :Delete, data: {:confirm =>'Are you sure?'} %><br/>
										<% end %>
									</div>
								</div>
							</div>
						<% end %>
					<% end %>
				</div>
			</div>
			<!-- Blog Sidebar-->
			<div class="col-lg-3">
				<!-- Search-->
				<div class="panel panel-default">
					<div class="panel-heading">Search</div>
					<div class="panel-body">
						<form class="form-horizontal">
							<div class="input-group">
								<input type="text" placeholder="Search for..." class="form-control">
								<span class="input-group-btn">
									<button type="button" class="btn btn-default">
									<em class="fa fa-search"></em>
									</button>
								</span>
							</div>
						</form>
					</div>
				</div>
				<!-- Categories-->
				<div class="panel panel-default">
					<div class="panel-heading">Categories</div>
					<div class="panel-body">
						<ul class="list-unstyled">
							<% Category.find("blog").children.each do |category| %>
								<li>
									<%= link_to category.name, blog_category_path(category.slug), :class => "#{ 'active' if category.slug == params[:category]}" %>
								</li>
							<% end %>							
						</ul>
					</div>
				</div>
				<!-- Tag Cloud-->
				<div class="panel panel-default">
					<div class="panel-heading">Tag Cloud</div>
					<div class="panel-body">
						<div id="jqcloud" class="center-block"></div>
					</div>
				</div>
				<!-- Ads-->
				<div class="panel panel-default">
					<div class="panel-heading">Ads</div>
					<div class="panel-body">
						<a href="">
							<img src="img/mockup.png" class="img-responsive img-thumbnail">
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>