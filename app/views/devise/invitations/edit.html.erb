<div class="block-center mt-xl wd-xl">
	 <!-- START panel-->
	<div class="panel panel-dark panel-flat">
		<div class="panel-body">
			<p class="text-center pv text-uppercase"><%= t 'devise.invitations.edit.header' %></p>
			<%= form_for resource, :as => resource_name, :url => invitation_path(resource_name), :html => { :method => :put } do |f| %>
			  <%= devise_error_messages! %>
			  <%= f.hidden_field :invitation_token %>

			<div class="form-group has-feedback">
				<%= f.label :password, class: "text-muted" %><br />
				<%= f.password_field :password, class: "form-control", autocomplete: "off", autofocus: true %>
			</div>
			<div class="form-group has-feedback">
				<%= f.label :password_confirmation, class: "text-muted" %><br />
				<%= f.password_field :password_confirmation, class: "form-control", autocomplete: "off", autofocus: true %>
			</div>

			  <%= f.submit t("devise.invitations.edit.submit_button"), class: "btn btn-block btn-primary mt-lg" %>
			<% end %>
		</div>
	</div>
</div>