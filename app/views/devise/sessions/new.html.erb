
<div class="block-center mt-xl wd-xl">
	 <!-- START panel-->
	 <div class="panel panel-dark panel-flat">
			<div class="panel-heading text-center">
				 <a href="#">
						<img src="<%= image_path('logos/icon.png') %>" alt="Image" class="block-center img-rounded" />
				 </a>
			</div>
			<div class="panel-body">
				<p class="text-center pv">SIGN IN TO CONTINUE.</p>
					<%= form_for(resource, as: resource_name, url: session_path(resource_name), :html => { class: "mb-lg", :role => "form", "data-parsley-validate" => "", :novalidate=>""}) do |f| %>
						<%= devise_error_messages! %>
						<div class="form-group has-feedback">
								<%= f.label :email %><br />
								<%= f.email_field :email, autofocus: true, placeholder: "Enter email",autocomplete: "off", required: "required", class: "form-control" %>
							 <span class="fa fa-envelope form-control-feedback text-muted"></span>
						</div>
						<div class="form-group has-feedback">
							<%= f.label :password %><br />
							<%= f.password_field :password, autocomplete: "off", placeholder: "Password", required: "required", class: "form-control" %>
							 <span class="fa fa-lock form-control-feedback text-muted"></span>
						</div>
						<div class="clearfix">
							 <div class="checkbox c-checkbox pull-left mt0">
								<% if devise_mapping.rememberable? -%>
									<label>
										<%= f.check_box :remember_me %>
										<span class="fa fa-check"></span><%= f.label :remember_me %>
									</label>
									</div>
								<% end -%>
							 <div class="pull-right">
								<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
									<%= link_to "Forgot your password?", new_password_path(resource_name), class: 'text-muted' %><br />
								<% end -%>
							 </div>
						</div>
						<%= f.button "Log in", class: "btn btn-block btn-primary mt-lg" %>
				 <% end %>
			</div>
	 </div>
	 <!-- END panel-->
</div>
