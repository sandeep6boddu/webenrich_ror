
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
<title>WebEnrich - Invitation Details</title>
</head>
	<body style="margin:0; padding:0;">
		<table class="table main-table" cellspacing="0" cellpadding="0" style = "width:100%; height: 420px; background: url(<%= image_url('job-field-bg.jpg')%>) repeat-x top #EBEBEB;">
			<thead>
				<tr>
					<th class="logo" style= "border: 0; text-align: left;">
						<%= image_tag "logo.png", :alt => 'logo', :class => 'img-responsive' %>	
					</th>
				</tr>
			</thead>
			<tbody>
				<tr style="height: 50px;">
					<td style= "border: 0;">
						<h2 style= "font-size: 24px; color:#ffffff; margin: 55px 0 0 56px;">
						Invitation Instructions
						</h2>
					</td>
				</tr>
				<tr>
					<td style= "">
						<table class="table sub-table" style="background: #fff; margin: 0 auto;">
							<tbody>
								<tr>
									<td style="border-top: 1px solid #eeeeee; padding: 8px 8px 8px 20px;">
										<p>	<%= t("devise.mailer.invitation_instructions.hello", email: @user.email) %>
										</p>
									</td>
								</tr>
								<tr>
									<td style="border-top: 1px solid #eeeeee; padding: 8px 8px 8px 20px;">
										<p> 
											<%= t("devise.mailer.invitation_instructions.someone_invited_you", url: root_url) %>
										</p>
									</td>
								</tr>
								<tr>
									<td style="border-top: 1px solid #eeeeee; padding: 8px 8px 8px 20px;">
										<p>
											<%= link_to t("devise.mailer.invitation_instructions.accept"), accept_invitation_url(@resource, :invitation_token => @token) %>
										</p>
									</td>
								</tr>
								<tr>
									<td style="border-top: 1px solid #eeeeee; padding: 8px 8px 8px 20px;">
										<p>	<%= t("devise.mailer.invitation_instructions.ignore").html_safe %>
										</p>
									</td>
								</tr>
							</tbody>
						</table>
					</td>
				</tr>
			</tbody>
		</table>
	</body>
</html>